# Build stage
FROM node:20-alpine as build

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install

COPY . .
RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html

# Expose port 3000 (or default nginx 80)
EXPOSE 80

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]


